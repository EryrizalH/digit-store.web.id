# HeroSMS Configuration Template
# Note: .env and .dev.vars are local and git-ignored.
# Wrangler v4 natively supports loading local secrets for local Worker development.
# Production secret name: HEROSMS_API_KEY (Set via `npx wrangler secret put HEROSMS_API_KEY`).

HEROSMS_API_KEY=your_herosms_api_key_here
HEROSMS_BASE_URL=https://hero-sms.com/stubs/handler_api.php
